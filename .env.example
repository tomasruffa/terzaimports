# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (direct Postgres — URL-encode special chars in password, e.g. @ → %40)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project.supabase.co:5432/postgres

# API (Railway inyecta PORT automáticamente)
API_PORT=4000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://your-app.vercel.app,https://your-admin.up.railway.app

# Next.js (Vercel)
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
